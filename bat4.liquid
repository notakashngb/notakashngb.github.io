<!-- Hint label -->
<div id="cube-hint">
  <span>🖱 Drag to spin &nbsp;·&nbsp; Scroll to zoom &nbsp;·&nbsp; Right-drag to pan</span>
</div>

<style>
#name-header {
  font-family: Inter, system-ui, sans-serif;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  display: inline-block;
  border-right: 2px solid currentColor;
  color: var(--global-text-color) !important;
}

#subtitle {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  opacity: 0;
  transition: opacity 0.6s ease;
  color: var(--global-text-color) !important;
}

#subtitle.subtitle-visible { opacity: 1; }

.profile-icons a:hover img { transform: translateY(-2px); }

footer { display: none !important; }

#rubiks-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  margin-left: calc(-50vw + 50%);
  margin-top: -150px;
  z-index: 1;
  background: radial-gradient(ellipse at center, #1a1a2e 0%, #0d0d1a 60%, #000 100%);
  overflow: hidden;
}

#rubiks-container canvas {
  display: block;
  width: 100% !important;
  height: 100% !important;
}

#cube-hint {
  position: fixed;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 9999;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(8px);
  color: rgba(255,255,255,0.75);
  font-family: Inter, system-ui, sans-serif;
  font-size: 0.78rem;
  letter-spacing: 0.04em;
  padding: 0.45rem 1.2rem;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.12);
  pointer-events: none;
  opacity: 1;
  transition: opacity 1s ease;
}

#cube-hint.hidden { opacity: 0; }

.post-header {
  position: relative;
  z-index: 20;
  margin-bottom: 0 !important;
  padding-bottom: 0 !important;
  background: transparent;
}

.post {
  margin-top: 0 !important;
  padding-top: 0 !important;
  background: transparent;
  margin-bottom: 0 !important;
  padding-bottom: 0 !important;
}

.post, article, .post-header { background: transparent !important; }

footer, .page-footer, .site-footer, #footer {
  display: none !important;
  margin: 0 !important;
  padding: 0 !important;
}

article {
  margin-top: 0 !important;
  padding-top: 0 !important;
  margin-bottom: 0 !important;
  padding-bottom: 0 !important;
}

html, body {
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  margin: 0 !important;
  margin-bottom: 0 !important;
}

.navbar, nav, .fixed-bottom, footer.sticky-bottom { display: none !important; }
body.sticky-bottom-footer { padding-bottom: 0 !important; margin-bottom: 0 !important; }

.side-icons {
  position: fixed;
  right: 1.5rem;
  top: 50%;
  transform: translateY(-50%);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.4rem;
}

.side-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease, opacity 0.2s ease;
  opacity: 0.85;
}

.side-icon svg { display: block; }
.side-icon:hover { transform: scale(1.15) translateX(-3px); opacity: 1; }
</style>

<!-- Three.js CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

<script>
(function () {
  /* ─── Typewriter ──────────────────────────────────────── */
  function typeNameWithTypos(el) {
    if (!el || el.dataset.typing === '1') return;
    el.dataset.typing = '1';
    const firstName = 'Akash ';
    const typos = ['Nabghirava', 'Nagabhirva', 'Nagabhirava'];
    let phase = 'first', firstIndex = 0, stage = 0, index = 0, deleting = false;
    function jitter(b) { return Math.max(10, b + Math.floor(Math.random() * 60) - 30); }
    function step() {
      if (!document.body.contains(el)) { el.dataset.typing = '0'; return; }
      if (phase === 'first') {
        el.textContent = firstName.slice(0, firstIndex + 1);
        firstIndex++;
        if (firstIndex < firstName.length) return setTimeout(step, jitter(110));
        phase = 'last'; index = 0; return setTimeout(step, 200);
      }
      const target = typos[stage] || '';
      if (!deleting) {
        el.textContent = firstName + target.slice(0, index + 1);
        index++;
        if (index < target.length) return setTimeout(step, jitter(120));
        if (stage < typos.length - 1) {
          setTimeout(() => {
            let dc = stage === 0 ? 8 : stage === 1 ? 3 : 1;
            dc = Math.min(dc, Math.max(1, target.length - 1));
            deleting = true; el.dataset.deletesLeft = String(dc); step();
          }, 400);
        } else {
          setTimeout(() => {
            el.style.borderRight = 'none'; el.dataset.typing = '0';
            const sub = document.getElementById('subtitle');
            if (sub) sub.classList.add('subtitle-visible');
          }, 320);
        }
      } else {
        let dl = parseInt(el.dataset.deletesLeft || '0', 10);
        if (dl <= 0) {
          deleting = false; stage++;
          setTimeout(() => { index = el.textContent.replace(firstName, '').length; step(); }, 200);
          return;
        }
        el.textContent = firstName + el.textContent.replace(firstName, '').slice(0, -1);
        el.dataset.deletesLeft = String(dl - 1);
        return setTimeout(step, 55);
      }
    }
    step();
  }

  /* ─── Profile rotator ─────────────────────────────────── */
  function initProfileRotator() {
    const imgEl = document.getElementById('profile-rotator');
    let images = [];
    try { images = JSON.parse('{{ page.profile.images | jsonify }}'); } catch (e) {}
    if (!images || !images.length) return;
    let idx = 0;
    document.addEventListener('keydown', function (e) {
      const a = document.activeElement;
      if (a && (a.tagName === 'INPUT' || a.tagName === 'TEXTAREA')) return;
      if (e.key === ' ') { e.preventDefault(); return; }
      if (/^[a-zA-Z]$/.test(e.key)) { idx = (idx + 1) % images.length; if (imgEl) imgEl.src = images[idx]; }
    });
  }

  /* ─── Rubik's Cube ────────────────────────────────────── */
  function initRubiksCube() {
    const container = document.getElementById('rubiks-container');
    if (!container) return;

    const W = container.clientWidth  || window.innerWidth;
    const H = container.clientHeight || window.innerHeight;

    /* Renderer */
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(window.devicePixelRatio);
    renderer.setSize(W, H);
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    container.appendChild(renderer.domElement);

    /* Scene */
    const scene = new THREE.Scene();

    /* Camera */
    const camera = new THREE.PerspectiveCamera(45, W / H, 0.1, 100);
    camera.position.set(5, 4, 7);
    camera.lookAt(0, 0, 0);

    /* Lights */
    scene.add(new THREE.AmbientLight(0xffffff, 0.5));
    const dir = new THREE.DirectionalLight(0xffffff, 0.9);
    dir.position.set(8, 12, 8);
    dir.castShadow = true;
    scene.add(dir);
    const fill = new THREE.DirectionalLight(0x8899ff, 0.3);
    fill.position.set(-6, -4, -6);
    scene.add(fill);

    /* Face colours: White, Yellow, Orange, Red, Blue, Green */
    const FACE_COLORS = [0xffffff, 0xffdd00, 0xff6600, 0xdd0000, 0x0055dd, 0x009933];
    /* +X, -X, +Y, -Y, +Z, -Z */
    const FACE_DIRS  = [
      new THREE.Vector3( 1,0,0), new THREE.Vector3(-1,0,0),
      new THREE.Vector3(0, 1,0), new THREE.Vector3(0,-1,0),
      new THREE.Vector3(0,0, 1), new THREE.Vector3(0,0,-1),
    ];

    /* Sticker material cache */
    const matCache = {};
    function stickerMat(hex) {
      if (!matCache[hex]) matCache[hex] = new THREE.MeshStandardMaterial({ color: hex, roughness: 0.25, metalness: 0.05 });
      return matCache[hex];
    }
    const blackMat = new THREE.MeshStandardMaterial({ color: 0x111111, roughness: 0.6 });

    const gap    = 0.04;    // gap between cubies
    const cubie  = 1.0;     // cubie side length
    const stk    = 0.04;    // sticker thickness
    const sOff   = cubie / 2 + stk / 2; // sticker offset from centre
    const sSize  = cubie * 0.82;        // sticker face size

    const group = new THREE.Group();
    scene.add(group);

    /* Build 27 cubies */
    for (let x = -1; x <= 1; x++) {
      for (let y = -1; y <= 1; y++) {
        for (let z = -1; z <= 1; z++) {
          const cubeGeo = new THREE.BoxGeometry(cubie, cubie, cubie);
          const cubeMesh = new THREE.Mesh(cubeGeo, blackMat);
          cubeMesh.position.set(
            x * (cubie + gap),
            y * (cubie + gap),
            z * (cubie + gap)
          );
          cubeMesh.castShadow = true;
          cubeMesh.receiveShadow = true;
          group.add(cubeMesh);

          /* Stickers */
          FACE_DIRS.forEach((dir, i) => {
            const cx = Math.round(dir.x), cy = Math.round(dir.y), cz = Math.round(dir.z);
            // Only add sticker if this cubie is on the outer face
            if (!((cx !== 0 && cx === x) || (cy !== 0 && cy === y) || (cz !== 0 && cz === z))) return;

            const sGeo = new THREE.BoxGeometry(
              cz !== 0 ? sSize : (cx !== 0 ? stk : sSize),
              cy !== 0 ? stk  : sSize,
              cx !== 0 ? sSize : (cz !== 0 ? stk : sSize)
            );
            // recompute for clear axis assignment
            let sw, sh, sd;
            if (cx !== 0) { sw = stk;   sh = sSize; sd = sSize; } // ±X face
            else if (cy !== 0) { sw = sSize; sh = stk;   sd = sSize; } // ±Y face
            else               { sw = sSize; sh = sSize; sd = stk;   } // ±Z face

            const sGeo2  = new THREE.BoxGeometry(sw, sh, sd);
            const stkMesh = new THREE.Mesh(sGeo2, stickerMat(FACE_COLORS[i]));
            stkMesh.position.set(
              x * (cubie + gap) + cx * sOff,
              y * (cubie + gap) + cy * sOff,
              z * (cubie + gap) + cz * sOff
            );
            group.add(stkMesh);
          });
        }
      }
    }

    /* Gentle idle rotation */
    const idleSpeed = { x: 0.003, y: 0.005 };

    /* ── Orbit controls (manual) ──────────────────────────── */
    let state = { rotating: false, panning: false };
    let prevMouse = { x: 0, y: 0 };
    let spherical = { theta: Math.atan2(5, 7), phi: Math.atan2(4, Math.sqrt(5*5+7*7)) };
    // store pan offset
    let panOffset = new THREE.Vector3(0, 0, 0);
    let radius    = camera.position.length();

    function getMouseButton(e) {
      if (e.button === 2) return 'right';
      if (e.button === 1) return 'middle';
      return 'left';
    }

    container.addEventListener('mousedown', (e) => {
      e.preventDefault();
      const btn = getMouseButton(e);
      if (btn === 'left')  { state.rotating = true; state.panning = false; }
      if (btn === 'right' || btn === 'middle') { state.panning = true; state.rotating = false; }
      prevMouse = { x: e.clientX, y: e.clientY };
    });

    window.addEventListener('mousemove', (e) => {
      if (!state.rotating && !state.panning) return;
      const dx = e.clientX - prevMouse.x;
      const dy = e.clientY - prevMouse.y;
      prevMouse = { x: e.clientX, y: e.clientY };

      if (state.rotating) {
        spherical.theta -= dx * 0.008;
        spherical.phi   -= dy * 0.008;
        spherical.phi    = Math.max(0.05, Math.min(Math.PI - 0.05, spherical.phi));
      }
      if (state.panning) {
        // pan in camera-local XY
        const panSpeed = 0.004 * radius;
        const right = new THREE.Vector3();
        const up    = new THREE.Vector3();
        camera.getWorldDirection(new THREE.Vector3()); // update matrix
        right.crossVectors(camera.getWorldDirection(new THREE.Vector3()), camera.up).normalize();
        up.copy(camera.up).normalize();
        panOffset.addScaledVector(right, -dx * panSpeed);
        panOffset.addScaledVector(up,     dy * panSpeed);
      }
    });

    window.addEventListener('mouseup', () => { state.rotating = false; state.panning = false; });

    container.addEventListener('wheel', (e) => {
      e.preventDefault();
      radius *= (1 + e.deltaY * 0.001);
      radius = Math.max(3, Math.min(20, radius));
    }, { passive: false });

    container.addEventListener('contextmenu', (e) => e.preventDefault());

    /* Touch support */
    let lastTouches = null;
    container.addEventListener('touchstart', (e) => {
      e.preventDefault();
      lastTouches = e.touches;
    }, { passive: false });

    container.addEventListener('touchmove', (e) => {
      e.preventDefault();
      if (!lastTouches) return;
      if (e.touches.length === 1 && lastTouches.length === 1) {
        const dx = e.touches[0].clientX - lastTouches[0].clientX;
        const dy = e.touches[0].clientY - lastTouches[0].clientY;
        spherical.theta -= dx * 0.008;
        spherical.phi   -= dy * 0.008;
        spherical.phi    = Math.max(0.05, Math.min(Math.PI - 0.05, spherical.phi));
      } else if (e.touches.length === 2 && lastTouches.length === 2) {
        const d0 = Math.hypot(lastTouches[0].clientX - lastTouches[1].clientX, lastTouches[0].clientY - lastTouches[1].clientY);
        const d1 = Math.hypot(e.touches[0].clientX   - e.touches[1].clientX,   e.touches[0].clientY   - e.touches[1].clientY);
        radius *= d0 / d1;
        radius = Math.max(3, Math.min(20, radius));
      }
      lastTouches = e.touches;
    }, { passive: false });

    container.addEventListener('touchend', () => { lastTouches = null; });

    /* Hide hint after 4 s */
    setTimeout(() => {
      const hint = document.getElementById('cube-hint');
      if (hint) hint.classList.add('hidden');
    }, 4000);

    /* Resize */
    window.addEventListener('resize', () => {
      const W2 = container.clientWidth, H2 = container.clientHeight;
      camera.aspect = W2 / H2;
      camera.updateProjectionMatrix();
      renderer.setSize(W2, H2);
    });

    /* Render loop */
    let userInteracted = false;
    container.addEventListener('mousedown', () => { userInteracted = true; });
    container.addEventListener('touchstart', () => { userInteracted = true; });

    function animate() {
      requestAnimationFrame(animate);

      if (!userInteracted) {
        // idle auto-spin
        group.rotation.x += idleSpeed.x;
        group.rotation.y += idleSpeed.y;
      }

      // Update camera from spherical
      camera.position.set(
        panOffset.x + radius * Math.sin(spherical.phi) * Math.sin(spherical.theta),
        panOffset.y + radius * Math.cos(spherical.phi),
        panOffset.z + radius * Math.sin(spherical.phi) * Math.cos(spherical.theta)
      );
      camera.lookAt(panOffset.x, panOffset.y, panOffset.z);

      renderer.render(scene, camera);
    }
    animate();
  }

  /* ─── Boot ────────────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {
    // Kill bottom padding
    document.body.style.setProperty('padding-bottom', '0px', 'important');
    new MutationObserver(() => {
      if (document.body.style.paddingBottom !== '0px')
        document.body.style.setProperty('padding-bottom', '0px', 'important');
    }).observe(document.body, { attributes: true, attributeFilter: ['style'] });

    const nameEl = document.getElementById('name-header');
    if (nameEl) typeNameWithTypos(nameEl);

    initProfileRotator();
    initRubiksCube();
  });
})();
</script>
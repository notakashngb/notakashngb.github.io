---
layout: default
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<div class="post">
  <header class="post-header">
    <h1 class="post-title" id="name-header"></h1>
    <p class="desc" id="subtitle">{{ page.subtitle }}</p>
  </header>

  <article>
    <div id="rubiks-container"></div>
    <div style="display: flex; gap: 3rem; align-items: flex-start;">
      <div style="flex: 1;">
        {{ content }}
      </div>
      {% if page.profile %}
      <div style="flex-shrink: 0;">
        <img id="profile-rotator"
            src="{{ page.profile.images[0] | relative_url }}"
            alt="profile"
            style="width: 270px; height: 360px; object-fit: cover; border-radius: 12px; margin-bottom: 20px;">
        <div class="profile-icons" style="display: flex; justify-content: center; gap: 16px;">
          <a href="https://open.spotify.com/user/obxzyzxv5yuu7qo1u3qaxvsqm?si=d17ead429e394d7d" target="_blank">
            <img src="/assets/icons/spotify.png" alt="Spotify" style="width: 36px; height: 36px; transition: transform 0.15s ease;">
          </a>
          <a href="https://www.linkedin.com/in/akash-nagabhirava-164155327/?skipRedirect=true" target="_blank">
            <img src="/assets/icons/linkedin.png" alt="LinkedIn" style="width: 36px; height: 36px; transition: transform 0.15s ease;">
          </a>
          <a href="https://github.com/akashngb" target="_blank">
            <img src="/assets/icons/github.png" alt="GitHub" style="width: 36px; height: 36px; transition: transform 0.15s ease;">
          </a>
          <a href="https://instagram.com/akash30n" target="_blank">
            <img src="/assets/icons/instagram.png" alt="Instagram" style="width: 36px; height: 36px; transition: transform 0.15s ease;">
          </a>
        </div>
      </div>
      {% endif %}
    </div>
  </article>
</div>

